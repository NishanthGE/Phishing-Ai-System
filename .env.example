# Environment Variables for AI Phishing Detection System
# Copy this file to .env and fill in your values

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Local MongoDB (default — make sure mongod is running)
MONGODB_URI=mongodb://localhost:27017/phishing-ai-system

# MongoDB Atlas (cloud — replace with your connection string)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/phishing-ai-system?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ─── Demo Login ────────────────────────────────────────────────────────────────
DEMO_USERNAME=admin
DEMO_PASSWORD=password123

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8081
NODE_ENV=development
